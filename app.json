{
  "expo": {
    "name": "TreeDBH",
    "slug": "tree-dbh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "treedbh",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow TreeDBH to save measurement photos.",
          "savePhotosPermission": "Allow TreeDBH to save measurement photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TreeDBH to access your photos."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0A1A0A"
      },
      "package": "com.treedbh.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.treedbh.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TreeDBH needs your camera to measure tree diameter using computer vision.",
        "NSPhotoLibraryUsageDescription": "TreeDBH saves measurement results to your photo library."
      }
    }
  }
}
